// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MemberSystemRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  USER
}

enum ShakhaType {
  PRABHAT
  SAYAM
}

model Shakha {
  id            String      @id @default(cuid())
  name          String
  establishDate DateTime?   @db.Date
  isActive      Boolean     @default(true)
  shakhaType    ShakhaType?
  timing        DateTime?   @db.Time
  location      String
  locationLat   String?
  locationLong  String?

  shakhaMember ShakhaMember[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Member {
  id         String           @id @default(cuid())
  name       String
  mobile     String?
  email      String?
  address    String?
  dob        DateTime?        @db.Date
  isActive   Boolean          @default(true)
  systemRole MemberSystemRole @default(USER)

  shakhaMember ShakhaMember[]
  credential   MemberCredential?

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model ShakhaMember {
  id String @id @default(cuid())

  shakhaId String
  shakha   Shakha @relation(fields: [shakhaId], references: [id])

  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  memberRole MemberRole[]

  isActive    Boolean   @default(true)
  joiningDate DateTime? @db.Date
  leavingDate DateTime? @db.Date

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  level       Int     @unique @default(0)
  isActive    Boolean @default(true)

  canAddMember    Boolean @default(false)
  canRemoveMember Boolean @default(false)
  canEditMember   Boolean @default(false)
  canAssignRole   Boolean @default(false)
  canViewAll      Boolean @default(true)

  memberRole MemberRole[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model MemberRole {
  id String @id @default(cuid())

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  shakhaMemberId String
  shakhaMember   ShakhaMember @relation(fields: [shakhaMemberId], references: [id])

  assignedAt DateTime  @default(now())
  revokedAt  DateTime?

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model MemberCredential {
  id       String @id @default(cuid())
  userName String @unique()

  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id])

  password   String
  firstLogin Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}
